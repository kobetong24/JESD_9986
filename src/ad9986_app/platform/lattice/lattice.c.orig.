#include <string.h>
#include <stdlib.h>
#include <stdint.h>
#include <fcntl.h>
#include <time.h>
#include <errno.h>
#include <unistd.h>
#include <sys/ioctl.h>
#include <linux/types.h>
#include <linux/spi/spidev.h>
#include <linux/gpio.h>
#include "lattice.h"
#include "cdmaapi.h"   /* for the cdma_* prototypes that we stub out below */

/*============= D E F I N E S ==============*/
/* log file limit */
#define MAX_FILE_NAME_LENGTH    64
#define MAX_LOG_LINE_LENGTH     1000
#define MAX_LOG_NUM_LINES       250000

/* AD9986 spi_xfer size_bytes encoding (see adi_ad9986_hal.c):
 *   - 8-bit  data access : low byte holds the total frame length (0x3)
 *   - 32-bit data access : bit 0x20000000 set, frame length 6 bytes
 */
#define LATTICE_SPI_32BIT_FLAG  0x20000000u

/**
 * @brief Per-device HAL configuration carried in adi_*_device_t.hal_info.user_data.
 *        With one chip-select per device the selection is handled by the spidev
 *        node; spi_cs is retained for logging/diagnostic context.
 */
typedef struct adi_hal_cfg {
    uint8_t   spi_cs;     /*!< informational chip-select index             */
    uint8_t   spi_msb;    /*!< 1 = MSB first (always 1 for these devices)  */
    uint8_t   bus;        /*!< 0 = AD9986 (SPI0 CS1), 1 = HMC7044 (SPI1)   */
} adi_hal_cfg_t;

/*============= D A T A ====================*/
/* spidev file descriptors */
static int       g_spi_jesd_fd    = -1;   /* SPI0 CS0 : JESD IP */
static int       g_spi_ad9986_fd  = -1;   /* SPI0 CS1 : AD9986  */
static int       g_spi_hmc7044_fd = -1;   /* SPI1 CS0 : HMC7044 */

/* RESETB GPIO line request fd (lazily opened) */
static int       g_resetb_req_fd  = -1;

/* spi access counters */
static uint32_t  g_spi_rd_cnt, g_spi_wr_cnt;

/* log file */
static FILE     *g_log_fd = NULL;
static char      g_log_file_name[MAX_FILE_NAME_LENGTH];
static uint32_t  g_log_line_num;

/* time base */
static struct    timespec ts_start;

/*============= C O D E ====================*/
static int32_t lattice_spi_dev_open(const char *dev, uint32_t hz, uint8_t extra_mode, int *out_fd);
static int32_t lattice_spi_xfer(int fd, uint32_t hz, uint8_t *tx, uint8_t *rx, uint32_t len);
static int32_t lattice_log_open(void);
static int32_t lattice_log_close(void);

/*
 * Open and configure a spidev node (mode, bits-per-word, max speed).
 */
static int32_t lattice_spi_dev_open(const char *dev, uint32_t hz, uint8_t extra_mode, int *out_fd)
{
    int      fd;
    uint8_t  mode = (uint8_t)(LATTICE_SPI_MODE | extra_mode);
    uint8_t  bits = LATTICE_SPI_BITS;
    uint32_t speed = hz;

    fd = open(dev, O_RDWR);
    if (fd < 0) {
        printf("lattice: cannot open spidev %s (%s).\r\n", dev, strerror(errno));
        return API_CMS_ERROR_HW_OPEN;
    }
    if ((ioctl(fd, SPI_IOC_WR_MODE, &mode) < 0) ||
        (ioctl(fd, SPI_IOC_WR_BITS_PER_WORD, &bits) < 0) ||
        (ioctl(fd, SPI_IOC_WR_MAX_SPEED_HZ, &speed) < 0)) {
        printf("lattice: cannot configure spidev %s (%s).\r\n", dev, strerror(errno));
        close(fd);
        return API_CMS_ERROR_HW_OPEN;
    }
    printf("lattice: spidev %s opened (mode 0x%02x, %d bits, %u Hz%s).\r\n",
           dev, mode, bits, speed, (extra_mode & SPI_3WIRE) ? ", 3-wire" : "");
    *out_fd = fd;
    return API_CMS_ERROR_OK;
}

/*
 * Perform a single full-duplex SPI transaction of len bytes.
 */
static int32_t lattice_spi_xfer(int fd, uint32_t hz, uint8_t *tx, uint8_t *rx, uint32_t len)
{
    struct spi_ioc_transfer tr;

    if (fd < 0) {
        return API_CMS_ERROR_SPI_XFER;
    }
    memset(&tr, 0, sizeof(tr));
    tr.tx_buf        = (unsigned long)tx;
    tr.rx_buf        = (unsigned long)rx;
    tr.len           = len;
    tr.speed_hz      = hz;
    tr.bits_per_word = LATTICE_SPI_BITS;
    tr.cs_change     = 0;

    if (ioctl(fd, SPI_IOC_MESSAGE(1), &tr) < 1) {
        printf("lattice: SPI transfer failed (%s).\r\n", strerror(errno));
        return API_CMS_ERROR_SPI_XFER;
    }
    return API_CMS_ERROR_OK;
}

/* ---------------------------------------------------------------------------
 * JESD IP register access over SPI0 CS0.
 *
 * These provide the same symbols that the adi_ads9_* JESD API links against
 * (originally the memory-mapped ADS9 implementation), so the JESD configuration
 * API is reused unchanged. The 6-byte frame layout is documented in lattice.h
 * and is configurable to match the Lattice register-bridge RTL.
 * ------------------------------------------------------------------------- */
int32_t ads9_axi_reg_write32(uint32_t reg_offset, uint32_t data)
{
    uint8_t  tx[6], rx[6] = {0};
    uint32_t addr = (reg_offset << LATTICE_JESD_ADDR_SHIFT) & LATTICE_JESD_ADDR_MASK;
    int32_t  err;

    tx[0] = LATTICE_JESD_CMD_WRITE;
    tx[1] = (uint8_t)(addr & 0xFF);
    tx[2] = (uint8_t)((data >> 24) & 0xFF);
    tx[3] = (uint8_t)((data >> 16) & 0xFF);
    tx[4] = (uint8_t)((data >>  8) & 0xFF);
    tx[5] = (uint8_t)((data >>  0) & 0xFF);

    err = lattice_spi_xfer(g_spi_jesd_fd, LATTICE_SPI_JESD_HZ, tx, rx, 6);
    if (err == API_CMS_ERROR_OK) {
        g_spi_wr_cnt++;
    }
    return err;
}

int32_t ads9_axi_reg_read32(uint32_t reg_offset, uint32_t *out_data)
{
    uint8_t  tx[6] = {0}, rx[6] = {0};
    uint32_t addr = (reg_offset << LATTICE_JESD_ADDR_SHIFT) & LATTICE_JESD_ADDR_MASK;
    int32_t  err;

    if (out_data == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }
    tx[0] = LATTICE_JESD_CMD_READ;
    tx[1] = (uint8_t)(addr & 0xFF);

    err = lattice_spi_xfer(g_spi_jesd_fd, LATTICE_SPI_JESD_HZ, tx, rx, 6);
    if (err == API_CMS_ERROR_OK) {
        *out_data = ((uint32_t)rx[0] << 24) | ((uint32_t)rx[1] << 16) |
                    ((uint32_t)rx[2] <<  8) | ((uint32_t)rx[3] <<  0);
        g_spi_rd_cnt++;
    }
    return err;
}

/* ---------------------------------------------------------------------------
 * Device SPI transfers
 * ------------------------------------------------------------------------- */
int32_t lattice_spi_xfer_ad9986(void *user_data, uint8_t *in_data, uint8_t *out_data, uint32_t size_bytes)
{
    uint32_t len;
    int32_t  err;

    (void)user_data;
    if (in_data == NULL || out_data == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }

    /* 2 instruction bytes + data bytes. 32-bit accesses are flagged with
     * LATTICE_SPI_32BIT_FLAG (6 bytes); others carry the byte count low (0x3). */
    if (size_bytes & LATTICE_SPI_32BIT_FLAG) {
        len = 6;
    } else {
        len = size_bytes & 0xFF;
        if (len == 0) {
            len = 3;
        }
    }

    /* AD9986 is a standard 4-wire SPI device: the read bit (0x80 of in_data[0])
     * and the trailing data bytes are handled directly by the device, so a
     * single full-duplex frame is sufficient. */
    err = lattice_spi_xfer(g_spi_ad9986_fd, LATTICE_SPI_AD9986_HZ, in_data, out_data, len);
    if (err != API_CMS_ERROR_OK) {
        return err;
    }
    if (in_data[0] & 0x80) {
        g_spi_rd_cnt++;
    } else {
        g_spi_wr_cnt++;
    }
    return API_CMS_ERROR_OK;
}

int32_t lattice_spi_xfer_hmc7044(void *user_data, uint8_t *in_data, uint8_t *out_data, uint32_t size_bytes)
{
    char     msg[100];
    va_list  argp = {0};
    uint32_t len;
    int32_t  err;
    uint16_t addr;
    uint8_t  is_read;

    if (in_data == NULL || out_data == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }
    if (g_spi_hmc7044_fd < 0) {
        return API_CMS_ERROR_SPI_XFER;
    }

    /* HMC7044 frames are 2 instruction bytes + data byte(s); typically 3 bytes. */
    len = (size_bytes & 0xFF);
    if (len == 0) {
        len = 3;
    }
    is_read = (in_data[0] & 0x80) ? 1 : 0;

#if LATTICE_SPI_HMC7044_3WIRE
    /*
     * 3-wire (shared SDIO) operation. The data line is bidirectional, so a
     * read is performed as two half-duplex phases inside a single chip-select
     * assertion: write the 2 instruction bytes, then read the data byte(s).
     * A write simply clocks out all bytes on the shared line.
     */
    if (is_read) {
        struct spi_ioc_transfer tr[2];
        memset(tr, 0, sizeof(tr));
        tr[0].tx_buf        = (unsigned long)in_data;            /* instruction */
        tr[0].len           = 2;
        tr[0].speed_hz      = LATTICE_SPI_HMC7044_HZ;
        tr[0].bits_per_word = LATTICE_SPI_BITS;
        tr[0].cs_change     = 0;                                 /* keep CS low */
        tr[1].rx_buf        = (unsigned long)&out_data[2];       /* data phase  */
        tr[1].len           = (len > 2) ? (len - 2) : 1;
        tr[1].speed_hz      = LATTICE_SPI_HMC7044_HZ;
        tr[1].bits_per_word = LATTICE_SPI_BITS;
        tr[1].cs_change     = 0;
        if (ioctl(g_spi_hmc7044_fd, SPI_IOC_MESSAGE(2), tr) < 1) {
            printf("lattice: HMC7044 3-wire read failed (%s).\r\n", strerror(errno));
            return API_CMS_ERROR_SPI_XFER;
        }
        err = API_CMS_ERROR_OK;
    } else {
        struct spi_ioc_transfer tr;
        memset(&tr, 0, sizeof(tr));
        tr.tx_buf        = (unsigned long)in_data;
        tr.len           = len;
        tr.speed_hz      = LATTICE_SPI_HMC7044_HZ;
        tr.bits_per_word = LATTICE_SPI_BITS;
        if (ioctl(g_spi_hmc7044_fd, SPI_IOC_MESSAGE(1), &tr) < 1) {
            printf("lattice: HMC7044 3-wire write failed (%s).\r\n", strerror(errno));
            return API_CMS_ERROR_SPI_XFER;
        }
        err = API_CMS_ERROR_OK;
    }
#else
    /* 4-wire full-duplex (board reworked for separate MISO or bridged data). */
    err = lattice_spi_xfer(g_spi_hmc7044_fd, LATTICE_SPI_HMC7044_HZ, in_data, out_data, len);
#endif
    if (err != API_CMS_ERROR_OK) {
        return err;
    }

    addr = (uint16_t)(((in_data[0] & 0x1F) << 8) | in_data[1]);
    if (is_read) {
        g_spi_rd_cnt++;
        sprintf(msg, "  7044: r@%.4x = %.2x", addr, out_data[2]);
    } else {
        g_spi_wr_cnt++;
        sprintf(msg, "  7044: w@%.4x = %.2x", addr, in_data[2]);
    }
    lattice_log_write(user_data, ADI_CMS_LOG_MSG, msg, argp);
    return API_CMS_ERROR_OK;
}

/* ---------------------------------------------------------------------------
 * AD9986 RESETB pin via the Linux GPIO character device (GPIO v2)
 * ------------------------------------------------------------------------- */
int32_t lattice_hw_rst_pin_ctrl_ad9986(void *user_data, uint8_t pin_level)
{
    struct gpio_v2_line_values vals;

    if (user_data == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }

    if (g_resetb_req_fd < 0) {
        int chip_fd;
        struct gpio_v2_line_request req;

        chip_fd = open(LATTICE_RESETB_CHIP, O_RDONLY);
        if (chip_fd < 0) {
            printf("lattice: cannot open gpiochip %s (%s).\r\n", LATTICE_RESETB_CHIP, strerror(errno));
            return API_CMS_ERROR_RESET_PIN_CTRL;
        }
        memset(&req, 0, sizeof(req));
        req.offsets[0]                  = LATTICE_RESETB_LINE;
        req.num_lines                   = 1;
        req.config.flags                = GPIO_V2_LINE_FLAG_OUTPUT;
        req.config.num_attrs            = 1;
        req.config.attrs[0].attr.id     = GPIO_V2_LINE_ATTR_ID_OUTPUT_VALUES;
        req.config.attrs[0].attr.values = pin_level ? 0x1 : 0x0;
        req.config.attrs[0].mask        = 0x1;
        strncpy(req.consumer, "ad9986_resetb", sizeof(req.consumer) - 1);

        if (ioctl(chip_fd, GPIO_V2_GET_LINE_IOCTL, &req) < 0) {
            printf("lattice: cannot request RESETB line %u (%s).\r\n", (unsigned)LATTICE_RESETB_LINE, strerror(errno));
            close(chip_fd);
            return API_CMS_ERROR_RESET_PIN_CTRL;
        }
        close(chip_fd);
        g_resetb_req_fd = req.fd;
    }

    memset(&vals, 0, sizeof(vals));
    vals.mask = 0x1;
    vals.bits = pin_level ? 0x1 : 0x0;
    if (ioctl(g_resetb_req_fd, GPIO_V2_LINE_SET_VALUES_IOCTL, &vals) < 0) {
        printf("lattice: cannot set RESETB value (%s).\r\n", strerror(errno));
        return API_CMS_ERROR_RESET_PIN_CTRL;
    }
    return API_CMS_ERROR_OK;
}

/* ---------------------------------------------------------------------------
 * Per-device HAL context
 * ------------------------------------------------------------------------- */
int32_t lattice_user_data_create_ad9986(adi_ad9986_device_t *device, uint8_t spi_cs)
{
    adi_hal_cfg_t *hal_cfg;
    if (device == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }
    hal_cfg = (adi_hal_cfg_t *)calloc(1, sizeof(adi_hal_cfg_t));
    if (hal_cfg == NULL) {
        return API_CMS_ERROR_ERROR;
    }
    hal_cfg->spi_cs  = spi_cs;
    hal_cfg->spi_msb = (device->hal_info.msb == SPI_MSB_FIRST) ? 1 : 0;
    hal_cfg->bus     = 0;
    device->hal_info.user_data = hal_cfg;
    return API_CMS_ERROR_OK;
}

int32_t lattice_user_data_create_hmc7044(adi_hmc7044_device_t *device, uint8_t spi_cs)
{
    adi_hal_cfg_t *hal_cfg;
    if (device == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }
    hal_cfg = (adi_hal_cfg_t *)calloc(1, sizeof(adi_hal_cfg_t));
    if (hal_cfg == NULL) {
        return API_CMS_ERROR_ERROR;
    }
    hal_cfg->spi_cs  = spi_cs;
    hal_cfg->spi_msb = 1;
    hal_cfg->bus     = 1;
    device->hal_info.user_data = hal_cfg;
    return API_CMS_ERROR_OK;
}

int32_t lattice_user_data_free(void **user_data)
{
    if (user_data == NULL) {
        return API_CMS_ERROR_NULL_PARAM;
    }
    free(*user_data);
    *user_data = NULL;
    return API_CMS_ERROR_OK;
}

int32_t lattice_wait_us(void *user_data, uint32_t time_us)
{
    (void)user_data;
    if (usleep(time_us) < 0) {
        return API_CMS_ERROR_DELAY_US;
    }
    return API_CMS_ERROR_OK;
}

/* ---------------------------------------------------------------------------
 * Logging
 * ------------------------------------------------------------------------- */
static int32_t lattice_log_open(void)
{
    int32_t err;
    struct tm tm = { 0 };
    time_t t = time(NULL);

    if ((g_log_fd != NULL) || (g_log_file_name[0] == '\0')) {
        return API_CMS_ERROR_LOG_OPEN;
    }
    g_log_fd = fopen(g_log_file_name, "w+");
    if (g_log_fd == NULL) {
        return API_CMS_ERROR_LOG_OPEN;
    }
    tm = *localtime(&t);
    err = fprintf(g_log_fd, "000.000: API log file[%04d-%02d-%02d %02d:%02d:%02d]\n\n",
                  tm.tm_year + 1900, tm.tm_mon + 1, tm.tm_mday, tm.tm_hour, tm.tm_min, tm.tm_sec);
    if (err < 0) {
        return API_CMS_ERROR_LOG_OPEN;
    }
    if (fflush(g_log_fd) < 0) {
        return API_CMS_ERROR_LOG_OPEN;
    }
    clock_gettime(CLOCK_REALTIME, &ts_start);
    return API_CMS_ERROR_OK;
}

static int32_t lattice_log_close(void)
{
    if (g_log_fd != NULL) {
        if (fflush(g_log_fd) < 0) {
            return API_CMS_ERROR_LOG_CLOSE;
        }
        if (fclose(g_log_fd) < 0) {
            return API_CMS_ERROR_LOG_CLOSE;
        }
        g_log_fd = NULL;
    }
    return API_CMS_ERROR_OK;
}

int32_t lattice_log_write(void *user_data, int32_t log_type, const char *comment, va_list argp)
{
    int32_t err;
    struct timespec ts_now;
    char log_msg[MAX_LOG_LINE_LENGTH] = {0};
    const char *log_type_str;

    (void)user_data;
    if ((g_log_fd == NULL) || (g_log_file_name[0] == '\0')) {
        return API_CMS_ERROR_LOG_WRITE;
    }
    if (g_log_line_num >= MAX_LOG_NUM_LINES) {
        rewind(g_log_fd);
        g_log_line_num = 0;
    }

    log_type_str = "MESSAGE:";
    if ((log_type & ADI_CMS_LOG_WARN) > 0) {
        log_type_str = "WARNING:";
    }
    if ((log_type & ADI_CMS_LOG_ERR) > 0) {
        log_type_str = "ERROR  :";
    }

    clock_gettime(CLOCK_REALTIME, &ts_now);
    ts_now.tv_nsec = ts_now.tv_nsec - ts_start.tv_nsec;
    ts_now.tv_sec  = ts_now.tv_sec  - ts_start.tv_sec;
    if (ts_now.tv_sec > 0 && ts_now.tv_nsec < 0) {
        ts_now.tv_nsec += 1e9;
        ts_now.tv_sec--;
    }

    err = snprintf(log_msg + strlen(log_msg), MAX_LOG_LINE_LENGTH, "%03d.%06d: %s ",
                   (int)ts_now.tv_sec, (int)(ts_now.tv_nsec / 1e3), log_type_str);
    if (err < 0) {
        return API_CMS_ERROR_LOG_WRITE;
    }
    if (vsprintf(log_msg + strlen(log_msg), comment, argp) < 0) {
        return API_CMS_ERROR_LOG_WRITE;
    }
    if (fprintf(g_log_fd, "%s\n", log_msg) < 0) {
        return API_CMS_ERROR_LOG_WRITE;
    }
    if (fflush(g_log_fd) < 0) {
        return API_CMS_ERROR_LOG_WRITE;
    }
    g_log_line_num += 1;
    return API_CMS_ERROR_OK;
}

/* ---------------------------------------------------------------------------
 * Platform open / close
 * ------------------------------------------------------------------------- */
int32_t lattice_hw_open(const char *log_file)
{
    int32_t err;

    g_spi_rd_cnt = 0;
    g_spi_wr_cnt = 0;

    strncpy(g_log_file_name, log_file, MAX_FILE_NAME_LENGTH - 1);
    if (err = lattice_log_open(), err != API_CMS_ERROR_OK) {
        return err;
    }

    /* SPI0 CS0 : JESD IP (4-wire, Mode 1 -- FPGA drives MISO on CLK rising) */
    if (err = lattice_spi_dev_open(LATTICE_SPI_JESD_DEV, LATTICE_SPI_JESD_HZ, LATTICE_SPI_JESD_MODE, &g_spi_jesd_fd),
        err != API_CMS_ERROR_OK) {
        return err;
    }
    /* SPI0 CS1 : AD9986 (4-wire) */
    if (err = lattice_spi_dev_open(LATTICE_SPI_AD9986_DEV, LATTICE_SPI_AD9986_HZ, 0, &g_spi_ad9986_fd),
        err != API_CMS_ERROR_OK) {
        return err;
    }
    /* SPI1 CS0 : HMC7044 (3-wire on this board: shared SDIO data line) */
    if (err = lattice_spi_dev_open(LATTICE_SPI_HMC7044_DEV, LATTICE_SPI_HMC7044_HZ,
                                   (LATTICE_SPI_HMC7044_3WIRE ? SPI_3WIRE : 0), &g_spi_hmc7044_fd),
        err != API_CMS_ERROR_OK) {
        return err;
    }
    return API_CMS_ERROR_OK;
}

int32_t lattice_hw_close(void)
{
    char    msg[100];
    va_list argp = {0};
    struct timespec ts_now;

    clock_gettime(CLOCK_REALTIME, &ts_now);
    ts_now.tv_nsec = ts_now.tv_nsec - ts_start.tv_nsec;
    ts_now.tv_sec  = ts_now.tv_sec  - ts_start.tv_sec;
    if (ts_now.tv_sec > 0 && ts_now.tv_nsec < 0) {
        ts_now.tv_nsec += 1e9;
        ts_now.tv_sec--;
    }
    printf("%03d.%03d: lattice_hw_close(), spi_rd = %d, spi_wr = %d, total = %d \r\n",
           (int)ts_now.tv_sec, (int)(ts_now.tv_nsec / 1e6), g_spi_rd_cnt, g_spi_wr_cnt, g_spi_rd_cnt + g_spi_wr_cnt);

    sprintf(msg, "lattice_hw_close(), spi_rd = %d, spi_wr = %d, total = %d ",
            g_spi_rd_cnt, g_spi_wr_cnt, g_spi_rd_cnt + g_spi_wr_cnt);
    lattice_log_write(NULL, ADI_CMS_LOG_MSG, msg, argp);

    if (g_spi_jesd_fd >= 0)    { close(g_spi_jesd_fd);    g_spi_jesd_fd = -1; }
    if (g_spi_ad9986_fd >= 0)  { close(g_spi_ad9986_fd);  g_spi_ad9986_fd = -1; }
    if (g_spi_hmc7044_fd >= 0) { close(g_spi_hmc7044_fd); g_spi_hmc7044_fd = -1; }
    if (g_resetb_req_fd >= 0)  { close(g_resetb_req_fd);  g_resetb_req_fd = -1; }

    return lattice_log_close();
}

/* ---------------------------------------------------------------------------
 * Unsupported CDMA data-capture stubs.
 *
 * The JESD204 DMA data-capture path is not supported on this platform (it
